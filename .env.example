# ============================================================================
# Auralis — AI Creative Studio · Root environment (used by docker-compose)
# Copy to `.env` and adjust. Everything has a sane local default.
# ============================================================================

# ---- Postgres ----
POSTGRES_USER=auralis
POSTGRES_PASSWORD=auralis
POSTGRES_DB=auralis
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Backend (FastAPI) ----
BACKEND_PORT=8000
# Full SQLAlchemy async URL. Inside docker-compose the host is `postgres`.
DATABASE_URL=postgresql+asyncpg://auralis:auralis@postgres:5432/auralis
REDIS_URL=redis://redis:6379/0
# JSON array or comma list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost

# ============================================================================
# AI PROVIDERS  — fill these to switch from mock mode to live generation.
# Leave any key empty to keep that surface in MOCK mode (realistic sample
# content / on-brand template images), so the app is always usable.
# ============================================================================

# --- TEXT (copy, product analysis, UGC scripts, scoring, video storyboards) ---
# OpenAI GPT.  Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- IMAGES --- Google (Nano Banana edits your scraped product photo into pro shots)
# AI Studio key MUST start with "AIza…" and have billing enabled:
#   https://aistudio.google.com/apikey
GOOGLE_API_KEY=
NANO_BANANA_MODEL=gemini-2.5-flash-image
IMAGEN_MODEL=imagen-4.0-generate-001

# --- VIDEO --- HeyGen talking-head avatar (a presenter showcases your product)
# API key:  https://app.heygen.com  ->  Settings -> API
HEYGEN_API_KEY=
# Auto-selects an Indian avatar + Indian-accent voice and ROTATES the avatar on
# every generation. Change the preferred accent via HEYGEN_REGION, or pin a
# specific presenter with HEYGEN_AVATAR_ID / HEYGEN_VOICE_ID.
HEYGEN_REGION=india
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ---- Storage ----
# `local` for MVP. Abstraction leaves room for `s3` / `r2` later.
STORAGE_BACKEND=local
STORAGE_DIR=/app/storage_data
# Public base URL the frontend uses to load generated assets.
STORAGE_PUBLIC_URL=http://localhost:8000/static

# ---- Frontend (Next.js) ----
FRONTEND_PORT=3000
# Browser-visible API base. Through nginx this is /api; direct it is :8000.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Auralis
