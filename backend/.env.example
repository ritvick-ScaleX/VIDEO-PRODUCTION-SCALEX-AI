# Backend-only env for running FastAPI/Celery outside docker-compose.
DATABASE_URL=postgresql+asyncpg://auralis:auralis@localhost:5432/auralis
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost

# --- AI providers (leave empty for mock mode) ---
# TEXT — OpenAI GPT (copy, analysis, UGC, scoring, storyboards)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# IMAGES — Google Nano Banana (edits scraped product photo) + Imagen fallback
GOOGLE_API_KEY=
NANO_BANANA_MODEL=gemini-2.5-flash-image
IMAGEN_MODEL=imagen-4.0-generate-001
# VIDEO — HeyGen talking-head avatar
HEYGEN_API_KEY=
HEYGEN_REGION=india
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

STORAGE_BACKEND=local
STORAGE_DIR=./storage_data
STORAGE_PUBLIC_URL=http://localhost:8000/static

RUN_MIGRATIONS_ON_START=true

# ---- Higgsfield (extra video models: Seedance, Kling, Gemini) ----
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=
# HIGGSFIELD_BASE_URL=https://platform.higgsfield.ai
# HIGGSFIELD_MODELS=  # optional JSON to override the default model list

# ---- Video voice + setting ----
# VEO_VOICE=a warm natural female Indian voice, mid-20s, Hinglish
# VEO_SETTING_BIAS=an authentic real Indian home / everyday Indian setting
